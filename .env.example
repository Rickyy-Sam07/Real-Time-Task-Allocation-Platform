KAFKA_BOOTSTRAP_SERVERS=kafka:9092
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=task_alloc
POSTGRES_USER=task_user
POSTGRES_PASSWORD=task_pass
REDIS_HOST=redis
REDIS_PORT=6379
API_PORT=8000

# Worker simulation controls
WORKER_EXECUTION_MODE=normal
WORKER_MIN_EXEC_SEC=1.0
WORKER_MAX_EXEC_SEC=3.0
WORKER_FAILURE_RATE=0.1
WORKER_DETERMINISTIC_DELAY_SEC=1.5
WORKER_DETERMINISTIC_FAIL_PERCENT=10
